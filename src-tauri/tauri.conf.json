{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnowYourDisk",
  "version": "0.1.21",
  "identifier": "io.github.Sanqi-normal.knowyourdisk",
  "build": {
    "beforeDevCommand": "npm run build:mcp && npm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:mcp:release && npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KnowYourDisk",
        "width": 1320,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.svg"
    ],
    "resources": [
      "binaries/fastscan-mcp.exe"
    ]
  }
}
