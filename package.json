{
  "name": "know-your-disk",
  "version": "0.1.21",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build",
    "dev:frontend": "vite --host 127.0.0.1",
    "build:frontend": "tsc --noEmit && vite build",
    "build:mcp": "cargo build -p fastscan-mcp && node scripts/copy-mcp.cjs debug",
    "build:mcp:release": "cargo build -p fastscan-mcp --release && node scripts/copy-mcp.cjs release",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "sharp": "^0.35.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
